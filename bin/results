#!/home/simbed/.rbenv/shims/ruby
# frozen_string_literal: true

# get the shebang line from $which ruby
# make this file executable with  $chmod +x file_name.rb

require "active_support"
require "active_support/core_ext/date/calculations"
require 'dotenv'
require 'yaml'
PROJECT_ROOT = File.expand_path('..', __dir__)
Dir.chdir(PROJECT_ROOT)
Dotenv.load('.env', '.env.secrets')
require_relative '../lib/results_manager'
require_relative '../lib/notification_manager'

date = Date.tomorrow.prev_occurring(:saturday)
# minimum_delay = ENV['MINIMUM_NOTIFICATION_DELAY_MINS'].to_i
# exit unless StateRecorder.new(date).ok_to_send_notification?(minimum_delay)

participations = YAML.load_file('config/participations.yml')

results_manager = ResultsManager.new(participations, date)
results_manager.record_raw_data
results_manager.process_results
results = results_manager.results
results_all_in = results_manager.results_all_in
NotificationManager.new(date, results, results_all_in).run if results_manager.notifiable_change

puts results
